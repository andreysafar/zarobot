# Zero-Bot Environment Configuration
# Copy this file to .env in the project root and update values

# Django Settings
SECRET_KEY=django-insecure-zero-bot-development-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=zero_bot
MONGODB_USER=zero_bot_app
MONGODB_PASSWORD=zero_bot_password_123

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis123

# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhooks/telegram/

# OpenAI API (for Iya personality)
OPENAI_API_KEY=your_openai_api_key_here

# TON Blockchain
TON_NETWORK=testnet
TON_API_KEY=your_ton_api_key_here
TON_WALLET_MNEMONIC=your_wallet_mnemonic_here

# Langflow Integration
LANGFLOW_API_URL=http://localhost:7860
LANGFLOW_API_KEY=your_langflow_api_key_here

# Ollama (for derValera personality)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ComfyUI (for neJny personality)
COMFYUI_API_URL=http://localhost:8188
COMFYUI_API_KEY=your_comfyui_api_key_here

# Computer Vision (for neJry personality)
CV_API_URL=http://localhost:8000
CV_API_KEY=your_cv_api_key_here

# Monitoring
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your_grafana_api_key_here

# Development Settings
LOG_LEVEL=DEBUG
ENABLE_DEBUG_TOOLBAR=True
MOCK_PAYMENTS=True
DISABLE_RATE_LIMITING=True

# Production Settings (uncomment for production)
# DEBUG=False
# MOCK_PAYMENTS=False
# DISABLE_RATE_LIMITING=False
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True 