# ═══════════════════════════════════════════
# Zero Bot Platform — Environment Variables
# ═══════════════════════════════════════════

# ── Telegram ──
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
IA_MOTHER_BOT_TOKEN=your_ia_mother_bot_token

# ── Solana ──
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PRIVATE_KEY=your_wallet_private_key

# ── Langflow ──
LANGFLOW_PASSWORD=admin123

# ── GitLab ──
GITLAB_URL=https://gitlab.com
GITLAB_RUNNER_TOKEN=your_runner_registration_token
REGISTRY_API_URL=https://registry.zerobot.ai
REGISTRY_TOKEN=your_registry_api_token

# ── AI Providers (for personalities) ──
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
