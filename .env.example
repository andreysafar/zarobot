# ==============================================
# ZERO BOT - ENVIRONMENT CONFIGURATION
# ==============================================

# ==============================================
# CORE API SETTINGS
# ==============================================
DEBUG=True
SECRET_KEY=your_very_secret_key_change_in_production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL (Production)
DATABASE_URL=postgresql://zero_bot:zero_bot_secure_pass@postgres:5432/zero_bot
POSTGRES_PASSWORD=zero_bot_secure_pass

# SQLite (Development fallback)
# DATABASE_URL=sqlite:///db.sqlite3

# ==============================================
# REDIS CONFIGURATION
# ==============================================
REDIS_URL=redis://:redis_secure_pass@redis-master:6379/0
REDIS_PASSWORD=redis_secure_pass

# ==============================================
# MESSAGE QUEUE (RabbitMQ)
# ==============================================
RABBITMQ_URL=amqp://zero_bot:rabbitmq_secure_pass@rabbitmq:5672/
RABBITMQ_USER=zero_bot
RABBITMQ_PASSWORD=rabbitmq_secure_pass

# ==============================================
# TELEGRAM INTEGRATION
# ==============================================
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Bot tokens (get from @BotFather)
IA_MOTHER_BOT_TOKEN=7312496733:AAGkY8KzYeQt3ysjv0fW81fU_Zsjem8hLs4
ZERO_BOT_TOKEN=477216183:AAH35Z0PD9UDiZx1_gIOWpdQrxxq_L6v6Gk
# Individual bot tokens will be managed dynamically

# ==============================================
# AI SERVICES
# ==============================================
# Anthropic Claude (required for AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (optional, for alternative AI models)
OPENAI_API_KEY=your_openai_api_key

# Perplexity (optional, for research features)
PERPLEXITY_API_KEY=your_perplexity_api_key

# ==============================================
# BLOCKCHAIN INTEGRATION
# ==============================================
# TON Blockchain
TON_API_KEY=your_ton_api_key
TON_TESTNET=true

# Solana Blockchain
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your_solana_private_key_base58

# ==============================================
# WEBAPP & FRONTEND
# ==============================================
# Main webapp URL (for Telegram WebApps)
WEBAPP_URL=https://your-domain.com

# TON Connect manifest
TON_CONNECT_MANIFEST_URL=https://your-domain.com/tonconnect-manifest.json

# ==============================================
# SECURITY & JWT
# ==============================================
JWT_SECRET=your_jwt_secret_key_for_auth
JWT_EXPIRATION=86400

# ==============================================
# MONITORING & LOGGING
# ==============================================
# Grafana
GRAFANA_PASSWORD=admin_secure_pass

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Sentry (optional, for error tracking)
SENTRY_DSN=your_sentry_dsn

# ==============================================
# EXTERNAL SERVICES
# ==============================================
# Email (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# File storage (AWS S3 or compatible)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_STORAGE_BUCKET_NAME=zero-bot-storage
AWS_S3_REGION_NAME=us-east-1

# ==============================================
# DEVELOPMENT SETTINGS
# ==============================================
# Enable development features
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILING=False

# Docker settings
DOCKER_HOST=unix:///var/run/docker.sock

# ==============================================
# PRODUCTION OVERRIDES
# ==============================================
# Set these in production environment:
# DEBUG=False
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True