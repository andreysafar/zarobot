# ═══════════════════════════════════
# Zero Bot Platform — .gitignore
# ═══════════════════════════════════

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Environment & secrets
.env
.env.backup
*.session

# IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
package-lock.json

# Database
*.sqlite3
db.sqlite3

# Logs
logs/
*.log

# Docker volumes data
data/

# Langflow data
langflow.db

# Telethon sessions
*.session

# Build artifacts
staticfiles/

# Monitoring
monitoring/

# Task Master
.taskmaster/
tasks/

# Cursor (local IDE state, do not commit)
.cursor/

# Roo
.roo/
.roomodes
.windsurfrules

# Test artifacts
.coverage
htmlcov/
